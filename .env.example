# RAI environment example. Copy locally and replace placeholders; never commit real secrets.

NODE_ENV=production
HOST=127.0.0.1
PORT=3009
TRUST_PROXY=1
PUBLIC_BASE_URL=https://rai.rick.sarl
CORS_ORIGINS=https://rai.rick.sarl,https://rai.000339.xyz,https://rai.rick.quest
ZTX6D_CALLBACK_URL=https://rai.rick.sarl/api/auth/ztx6d/callback
OPENROUTER_HTTP_REFERER=https://rai.rick.sarl
OPENROUTER_APP_TITLE=RAI

# Required secrets. Use long random values.
JWT_SECRET=replace-with-at-least-32-random-characters
ADMIN_JWT_SECRET=replace-with-at-least-32-random-characters
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=replace-with-bcrypt-hash

# Production admin login requires TOTP by default.
RAI_ADMIN_TOTP_REQUIRED=true
ADMIN_TOTP_SECRET=replace-with-base32-totp-secret
RAI_TOTP_ISSUER=RAI
RAI_PASSKEY_RP_NAME=RAI
RAI_PASSKEY_ALLOW_LOCALHOST=false
ADMIN_TOKEN_EXPIRES_IN=12h

# Email verification.
RESEND_API_KEY=replace-with-resend-api-key
# Must be a real sender address, for example: RAI <noreply@mail.rick.quest>
RESEND_FROM_EMAIL=RAI <noreply@example.com>
RESEND_API_URL=https://api.resend.com/emails
RAI_RESEND_TIMEOUT_MS=12000
RAI_ALLOW_RESEND_TEST_MODE_EMAIL_BYPASS=false

# Provider keys and endpoints.
OPENROUTER_API_KEY=replace-with-openrouter-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions
NEWAPI_API_KEY=replace-with-newapi-key
NEWAPI_BASE_URL=https://api.example.com/v1/chat/completions
GOOGLE_GEMINI_API_KEY=replace-with-gemini-key
GOOGLE_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/models
SILICONFLOW_API_KEY=replace-with-siliconflow-key
SILICONFLOW_IMAGE_GENERATION_URL=https://api.siliconflow.cn/v1/images/generations
TAVILY_API_KEY=replace-with-tavily-key
ALIYUN_API_KEY=replace-with-aliyun-key
DEEPSEEK_API_KEY=replace-with-deepseek-key

# Runtime policy.
RAI_GENERATED_IMAGE_ALLOWED_HOSTS=siliconflow.cn
RAI_GENERATED_IMAGE_FETCH_TIMEOUT_MS=8000
RAI_GENERATED_IMAGE_MAX_BYTES=20971520
RAI_IMAGE_URL_HEAD_TIMEOUT_MS=2000
RAI_IMAGE_FETCH_MAX_REDIRECTS=3
RAI_CSP_ALLOW_LOCAL_CONNECT=false
RAI_CSP_STRICT_SCRIPT_SRC=false
RAI_RUNTIME_REPORT_PATH=/rick/apps/rai/rai运行报告.md
RAI_UPLOAD_MAX_FILE_MB=20
RAI_UPLOAD_USER_TOTAL_MB=500
RAI_UPLOAD_USER_MAX_FILES=300
RAI_MAX_CONCURRENT_REQUESTS_PER_USER=2
RAI_CHAT_QUOTA_PER_MINUTE=6
RAI_CHAT_QUOTA_PER_5H=120
RAI_CHAT_QUOTA_PER_WEEK=800

# Optional branding/runtime.
RAI_BRAND_NAME=RAI
RAI_BRAND_SHORT_NAME=RAI
RAI_BRAND_BADGE=
RAI_BRAND_TITLE=RAI
RAI_DEFAULT_DISABLED_MODELS=
RAI_DEFAULT_DOMAIN_NOTICE_ENABLED=true
RAI_DEFAULT_DOMAIN_NOTICE_URL=https://rai.rick.sarl/
RAI_LONG_MEMORY_DEFAULT_ENABLED=false
